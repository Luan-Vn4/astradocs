{
	"name": "astradocs-monorepo",
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@types/node": "^25.3.0",
		"@types/write-file-atomic": "^4.0.3"
	},
	"private": true,
	"scripts": {
		"cli": "bun run --cwd packages/cli",
		"core": "bun run --cwd packages/core",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"workspaces": [
		"packages/*"
	],
	"dependencies": {
		"p-map": "^7.0.4",
		"remeda": "^2.33.6",
		"write-file-atomic": "^7.0.0"
	}
}
